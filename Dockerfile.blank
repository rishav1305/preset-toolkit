FROM ubuntu:24.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl git ca-certificates openssl openssh-client \
    && rm -rf /var/lib/apt/lists/*

# Inject corporate Zscaler root CA
COPY zscaler-ca.pem /usr/local/share/ca-certificates/zscaler-root.crt
RUN update-ca-certificates

# Point Node.js to the updated system CA bundle
ENV NODE_EXTRA_CA_CERTS=/etc/ssl/certs/ca-certificates.crt

# Node.js 20
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

# Create user with proper ownership
RUN useradd -m -s /bin/bash testuser && \
    mkdir -p /home/testuser/.npm /home/testuser/.claude && \
    chown -R testuser:testuser /home/testuser

# Install Claude Code globally
RUN npm install -g @anthropic-ai/claude-code

USER testuser
WORKDIR /home/testuser

# Force GitHub SSH URLs to use HTTPS (no SSH keys in container)
RUN git config --global url."https://github.com/".insteadOf "git@github.com:" && \
    git config --global url."https://github.com/".insteadOf "ssh://git@github.com/"

CMD ["bash"]
